{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghl-email-services-toolkit/contracts/current-runtime/auth-check-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "timestamp", "locationId", "checks", "message"],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "locationId": {
      "type": ["string", "null"]
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["emailBuilder", "users"],
      "properties": {
        "emailBuilder": {
          "$ref": "#/$defs/probeResult"
        },
        "users": {
          "$ref": "#/$defs/probeResult"
        }
      }
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "errorCode": {
      "type": "string",
      "enum": [
        "MISSING_TOKEN",
        "MISSING_LOCATION_ID",
        "AUTH_FAILED",
        "LOCATION_SCOPE_FAILED",
        "NETWORK_ERROR",
        "UNKNOWN_ERROR"
      ]
    }
  },
  "$defs": {
    "probeResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "endpoint", "status", "message", "diagnostics"],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "endpoint": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": ["integer", "null"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "responseSnippet"],
          "properties": {
            "status": {
              "type": ["integer", "null"]
            },
            "responseSnippet": {
              "type": ["string", "null"]
            }
          }
        }
      }
    }
  }
}
